@page "/"
@inject HttpClient http

<h1>WebToDesk</h1>

<p>Статус: <b>@status</b></p>

<button @onclick="ShowOpenModal">Открыть приложение</button>

@code {
    string status = "Готово";

    async Task ShowOpenModal()
    {
        status = "Шаг 1: Отправка POST...";
        Console.WriteLine(status);

        try
        {
            var res = await http.PostAsync("http://localhost:5298/open-app", null);

            status = $"Шаг 2: Получен ответ: {res.StatusCode}";
            Console.WriteLine(status);
    
            if (res.IsSuccessStatusCode)
            {
                status = "Шаг 3: Приложение открыто!";
            }
            else
            {
                status = $"Шаг 3: Ошибка запуска, HTTP {(int)res.StatusCode}";
            }
            Console.WriteLine(status);
        }
        catch (Exception ex)
        {
            status = $"Шаг X: Исключение: {ex.Message}";
            Console.WriteLine(status);
        }
    }
}