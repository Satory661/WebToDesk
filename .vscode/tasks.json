{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "terminate-dotnet",
      "type": "shell",
      "command": "Get-Process dotnet, minio -ErrorAction SilentlyContinue | Stop-Process -Force -ErrorAction SilentlyContinue; Write-Host 'Cleanup done.'",
      "presentation": { "reveal": "silent" }
    },
    {
      "label": "run-minio",
      "type": "shell",
      "command": "Start-Process './minio.exe' -ArgumentList 'server', 'C:/minio_data', '--console-address', ':9001' -WindowStyle Hidden",
      "problemMatcher": []
    },
    {
      "label": "build-desktop",
      "type": "process",
      "command": "dotnet",
      "args": [
        "build",
        "${workspaceFolder}/src/desktop/Desktop.App/WebToDesk/WebToDesk.csproj",
        "-c",
        "Debug"
      ],
      "problemMatcher": "$msCompile"
    },
    {
      "label": "run-api",
      "type": "process",
      "command": "dotnet",
      "args": [
        "run",
        "--project",
        "${workspaceFolder}/src/api/WebToDesk.Api/WebToDesk.Api.csproj",
        "-c",
        "Debug"
      ],
      "isBackground": true,
      "problemMatcher": {
        "owner": "run-api",
        "background": {
          "activeOnStart": true,
          "beginsPattern": "Building|Сборка",
          "endsPattern": "Now listening on:"
        },
        "pattern": { "regexp": "^(.*)$" }
      }
    },
    {
      "label": "run-web",
      "type": "process",
      "command": "dotnet",
      "args": [
        "run",
        "--project",
        "${workspaceFolder}/src/web/WebToDesk.Web/WebToDesk.Web.csproj",
        "-c",
        "Debug"
      ],
      "isBackground": true,
      "problemMatcher": {
        "owner": "run-web",
        "background": {
          "activeOnStart": true,
          "beginsPattern": "Building|Сборка",
          "endsPattern": "Now listening on:"
        },
        "pattern": { "regexp": "^(.*)$" }
      }
    },
    {
      "label": "wait-a-bit",
      "type": "shell",
      "command": "Start-Sleep -Seconds 5",
      "problemMatcher": []
    },
    {
      "label": "start-all",
      "dependsOrder": "sequence",
      "dependsOn": [
        "terminate-dotnet",
        "run-minio",
        "build-desktop",
        "run-api",
        "run-web",
        "wait-a-bit"
      ],
      "problemMatcher": []
    }
  ]
}